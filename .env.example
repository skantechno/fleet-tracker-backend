# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# --- Auth ---
JWT_SECRET=replace-this-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# --- PostgreSQL (matches docker-compose.yml) ---
DATABASE_URL=postgresql://fleet:fleet@localhost:5432/fleet

# --- InfluxDB (matches docker-compose.yml) ---
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=fleet-tracker-dev-token-do-not-use-in-prod
INFLUX_ORG=fleet
INFLUX_BUCKET=telemetry

# --- MQTT (matches docker-compose.yml EMQX) ---
MQTT_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=fleet-tracker-backend
MQTT_USERNAME=
MQTT_PASSWORD=

# --- Simulator (used by simulator/index.ts) ---
SIM_VEHICLE_COUNT=5
SIM_INTERVAL_MS=2000
